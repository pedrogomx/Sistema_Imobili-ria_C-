using System;
using System.Diagnostics;
using System.IO;

namespace SistemaImobiliaria
{
    class Program
    {
        private const char separadorCampo = '|';

        // Arquivos
        static string arquivoImoveis = "imoveis.txt";
        static string arquivosParametros = "parametros.txt";

        // Entrada
        static void Main(string[] args)
        {
            Console.OutputEncoding = System.Text.Encoding.UTF8;
            Console.InputEncoding = System.Text.Encoding.UTF8;
            ExibirMenu();
        }

        static void ExibirMenu()
        {
            while (true)
            {
                Console.Clear();
                Console.WriteLine("=== Sistema de Imobiliária ===");
                Console.WriteLine("1. Cadastrar Parâmetros de Comissão");
                Console.WriteLine("2. Cadastrar Imóvel");
                Console.WriteLine("3. Listar Imóveis e Estimativa de Comissão");
                Console.WriteLine("4. Atualizar Status de Venda");
                Console.WriteLine("5. Sair");
                Console.Write("Escolha uma opção: ");

                int opcao = LerInteiroOuNegativo();

                switch (opcao)
                {
                    case 1:
                        CadastrarParametros();
                        break;
                    case 2:
                        CadastrarImovel();
                        break;
                    case 3:
                        ListarImoveis();
                        break;
                    case 4:
                        AtualizarStatus();
                        break;
                    case 5:
                        Console.WriteLine("Encerrando o sistema...");
                        return;
                    default:
                        Console.WriteLine("Opção inválida. Pressione Enter para continuar.");
                        Console.ReadLine();
                        break;
                }
            }
        }

        private static void AtualizarStatus()
        {
            throw new NotImplementedException();
        }

        // Lê uma única tecla numérica sem precisar pressionar Enter
        static int LerInteiroOuNegativo()
        {
            var key = Console.ReadKey(intercept: true);
            Console.WriteLine(key.KeyChar);
            if (char.IsDigit(key.KeyChar))
            {
                return (int)char.GetNumericValue(key.KeyChar);
            }
            return -1;
        }

        static string LerTexto(string prompt)
        {
            Console.Write(prompt);
            return Console.ReadLine() ?? string.Empty;
        }

        static void CadastrarParametros()
        {
            Console.Clear();
            Console.WriteLine("=== Cadastrar Parametros ===");

            double[] percentuais = new double[4]; // Fiz isso para que seja lido até 4 algarismos no mesmo numero, ou seja, 10,57% por exemplo, e não apenas 10%

            string[] faixas = {
                               "Faixa 1 - Ate 50 m2",
                               "Faixa 2 - De 51 a 300 m2",
                               "Faixa 3 - De 301 a 2000 m2",
                               "Faixa 4 - Acima de 2000 m2"
                              };

            // Aqui vou criar um loop para ler os percentuais
            for (int i = 0; i < 4; i++)
            {
                bool valido = false;
                while (!valido) // Isso é para que o usuário repita ate que digite um número valido
                {
                    Console.Write($"Insira o percentual de comissão para {faixas[i]} (%): ");
                    try
                    {
                        string entrada = (Console.ReadLine() ?? string.Empty).Replace(",", "."); // Permite que o usuário use vírgula ou ponto como separador decimal
                        percentuais[i] = double.Parse(entrada, System.Globalization.CultureInfo.InvariantCulture); // Converte a string para double usando a cultura invariante para garantir que o ponto seja interpretado como separador decimal
                        valido = true; //Estou marcando como válido para sair do loop
                    }
                    catch
                    {
                        Console.WriteLine("Entrada inválida. Por favor, insira um número válido para o percentual de comissão.");
                    }
                }
            }

            try
            {
                string[] linhas =
                {
                    percentuais[0].ToString(System.Globalization.CultureInfo.InvariantCulture),
                    percentuais[1].ToString(System.Globalization.CultureInfo.InvariantCulture),
                    percentuais[2].ToString(System.Globalization.CultureInfo.InvariantCulture),
                    percentuais[3].ToString(System.Globalization.CultureInfo.InvariantCulture)
                };

                File.WriteAllLines(arquivosParametros, linhas); // Escreve os percentuais no arquivo, cada um em uma linha
                Console.WriteLine("Parâmetros de comissão cadastrados com sucesso!");
            }
            catch
            {
                Console.WriteLine("Ocorreu um erro ao salvar os parâmetros. Por favor, tente novamente.");
            }

            Console.WriteLine("\nPressione Enter para voltar ao menu.");
            Console.ReadLine();
        }

        static void CadastrarImovel()
        {
            Console.Clear();
            Console.WriteLine("=== Cadastrar Imóvel ===");

            Console.Write("Insira o id do imóvel: ");
            string idimovel = Console.ReadLine();
            int agr = Convert.ToInt32(idimovel);
            Console.Write("Insira o nome do imóvel: ");
            string nomeimovel = Console.ReadLine();
            Console.Write("Insira a descrição do imóvel: ");
            string descricaoimovel = Console.ReadLine();
            Console.Write("Insira o endereço do imóvel: ");
            string enderecoimovel = Console.ReadLine();
            Console.Write("Insira o m² do imóvel: ");
            string metragemimovel = Console.ReadLine();
            int agr2 = Convert.ToInt32(metragemimovel);
            Console.Write("Insira o preço do imóvel: ");
            string precoimovel = Console.ReadLine();
            int agr3 = Convert.ToInt32(precoimovel);

            string message = $"ID: {idimovel} | Nome: {nomeimovel} | Descrição: {descricaoimovel} | Endereço: {enderecoimovel} | Metragem: {metragemimovel}m² | Preço: R$ {precoimovel}";

            Console.WriteLine("\n" + message);

            Console.WriteLine($"Diretório atual: {Directory.GetCurrentDirectory()}");
            Console.WriteLine($"Caminho do arquivo: {Path.GetFullPath(arquivoImoveis)}");

            try
            {
                using (var writer = new System.IO.StreamWriter(arquivoImoveis, true))
                {
                    writer.WriteLine(message);
                }
                Console.WriteLine(" Imóvel cadastrado com sucesso!");
                Console.WriteLine($" Arquivo salvo em: {Path.GetFullPath(arquivoImoveis)}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($" Erro ao salvar: {ex.Message}");
                Console.WriteLine($" Stack trace: {ex.StackTrace}");
            }

            Console.WriteLine("\nPressione Enter para voltar ao menu.");
            Console.ReadLine();
        }

        static void ListarImoveis()
        {
            Console.Clear();
            Console.WriteLine("=== Listar iImóveis comissão ===");

            //Primeiro vou verificar se o arqivo existe
            if (!File.Exists(arquivosParametros))
            {
                Console.WriteLine("Parâmetros de comissão não encontrados. Por favor, cadastre os parâmetros antes de listar os imóveis.");
                Console.ReadLine();
                return;
            }

            //Agora tenho que fazer que o arquivo de paremtros seja lido
            double[] percentuais = new double[4];
            try
            {
                string[] linhasParam = File.ReadAllLines(arquivosParametros); // Lê os percentuais do arquivo
                for (int i = 0; i < 4; i++)
                {
                    percentuais[i] = double.Parse(linhasParam[i], System.Globalization.CultureInfo.InvariantCulture); // Converte as linhas para double
                }

            }
            catch
            {
                Console.WriteLine("Erro ao ler os parâmetros de comissão. Por favor, verifique o arquivo de parâmetros.");
                Console.ReadLine();
                return;
            }

            //Agora vou verificar se o arquivo de imóveis existe
            if (!File.Exists(arquivoImoveis))
            {
                Console.WriteLine("Nenhum imóvel cadastrado. Por favor, cadastre um imóvel antes de listar.");
                Console.ReadLine();
                return;
            }
            string[] linhasImoveis = File.ReadAllLines(arquivoImoveis); // Lendo todos os imóveis do arquivo
            foreach (string line in linhasImoveis) // O foreach para ler cada linha do arquivo de imóveis
            {
                if (string.IsNullOrWhiteSpace(line)) continue;
                string[] campos = line.Split(separadorCampo);

                try
                {
                    // Extraindo os campos do imóvel
                    int id = int.Parse(campos[0].Split(':')[1].Trim());
                    string nome = campos[1].Split(':')[1].Trim();
                    string descricao = campos[2].Split(':')[1].Trim();
                    string endereco = campos[3].Split(':')[1].Trim();
                    double metragem = double.Parse(campos[4].Split(':')[1].Trim().Replace("m²", "").Trim(), System.Globalization.CultureInfo.InvariantCulture);
                    double preco = double.Parse(campos[5].Split(':')[1].Trim().Replace("R$", "").Trim(), System.Globalization.CultureInfo.InvariantCulture);
                    string status = campos.Length > 6 ? campos[6].Split(':')[1].Trim() : "Disponível"; // Verifica se o status está presente, caso contrário, assume "Disponível"

                    // Determinando percentual de comissão com base na metragem
                    double percentualComissao;
                    string faixa;
                    if (metragem <= 50)
                    {
                        percentualComissao = percentuais[0];
                        faixa = "Faixa 1";
                    }
                    else if (metragem <= 300)
                    {
                        percentualComissao = percentuais[1];
                        faixa = "Faixa 2";
                    }
                    else if (metragem <= 2000)
                    {
                        percentualComissao = percentuais[2];
                        faixa = "Faixa 3";
                    }
                    else
                    {
                        percentualComissao = percentuais[3];
                        faixa = "Faixa 4";
                    }

                    // Calculando a comissão
                    double comissao = preco * percentualComissao / 100.0;

                    Console.WriteLine($"ID: {id} | Nome: {nome} | Preço: R$ {preco:F2} | Metragem: {metragem}m² | {faixa} ({percentualComissao}%) | Comissão estimada: R$ {comissao:F2} | Status: {status}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Erro ao processar linha: '{line}'. Detalhe: {ex.Message}");
                }
            }

            Console.WriteLine("\nPressione Enter para voltar ao menu.");
            Console.ReadLine();
        }

        static void AtualizarStatus()
        {
            Console.Clear();
            Console.WriteLine("=== Atualizar Status de Venda ===");

            // Verificar se o arquivo de imóveis existe
            if (!File.Exists(arquivoImoveis))
            {
                Console.WriteLine("Nenhum imóvel cadastrado.");
                Console.WriteLine("Pressione Enter para voltar.");
                Console.ReadLine();
                return;
            }

            // Listar imóveis disponíveis
            string[] linhasImoveis = File.ReadAllLines(arquivoImoveis);
            if (linhasImoveis.Length == 0)
            {
                Console.WriteLine("Nenhum imóvel cadastrado.");
                Console.WriteLine("Pressione Enter para voltar.");
                Console.ReadLine();
                return;
            }

            Console.WriteLine("Imóveis cadastrados:");
            for (int i = 0; i < linhasImoveis.Length; i++)
            {
                if (string.IsNullOrWhiteSpace(linhasImoveis[i])) continue;
                string[] campos = linhasImoveis[i].Split(separadorCampo);
                try
                {
                    int id = int.Parse(campos[0].Split(':')[1].Trim());
                    string nome = campos[1].Split(':')[1].Trim();
                    Console.WriteLine($"{i + 1}. ID: {id} | Nome: {nome}");
                }
                catch { }
            }

            // Solicitar qual imóvel atualizar
            Console.Write("\nDigite o número do imóvel a atualizar (ou 0 para cancelar): ");
            if (!int.TryParse(Console.ReadLine(), out int escolha) || escolha < 1 || escolha > linhasImoveis.Length)
            {
                Console.WriteLine("Opção inválida.");
                Console.ReadLine();
                return;
            }

            string linhaEscolhida = linhasImoveis[escolha - 1];

            // Exibir status disponíveis
            Console.WriteLine("\nStatus disponíveis:");
            Console.WriteLine("1. Disponível");
            Console.WriteLine("2. Vendido");
            Console.WriteLine("3. Alugado");
            Console.Write("Escolha o novo status (1-3): ");

            if (!int.TryParse(Console.ReadLine(), out int statusEscolha) || statusEscolha < 1 || statusEscolha > 3)
            {
                Console.WriteLine("Opção inválida.");
                Console.ReadLine();
                return;
            }

            string[] statusOpcoes = { "Disponível", "Vendido", "Alugado" };
            string novoStatus = statusOpcoes[statusEscolha - 1];

            // Atualizar a linha com o novo status
            string linhaAtualizada = linhaEscolhida + $" | Status: {novoStatus}";

            try
            {
                // Substituir a linha no arquivo
                linhasImoveis[escolha - 1] = linhaAtualizada;
                File.WriteAllLines(arquivoImoveis, linhasImoveis);

                Console.WriteLine($"\n✓ Status atualizado para '{novoStatus}' com sucesso!");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"\n✗ Erro ao atualizar status: {ex.Message}");
            }

            Console.WriteLine("Pressione Enter para voltar ao menu.");
            Console.ReadLine();
        }

    }
}
