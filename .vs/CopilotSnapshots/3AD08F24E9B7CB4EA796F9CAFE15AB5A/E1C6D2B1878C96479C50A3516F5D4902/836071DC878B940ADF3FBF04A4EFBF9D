using System;
using System.Collections;
using System.Diagnostics;

namespace SistemaImobiliaria
{
    class Program
    {
        // Arquivos
        static string arquivoImoveis = "imoveis.txt";
        static string arquivosParametros = "parametros.txt";

        // Entrada
        static void Main(string[] args)
        {
            Console.OutputEncoding = System.Text.Encoding.UTF8;
            Console.InputEncoding = System.Text.Encoding.UTF8;
            ExibirMenu();
        }

        // ■■■ Metodos de cada funcionalidade ■■■
        static void CadastrarParametros() { }
        static void CadastrarImovel() { }
        static void ListarImoveis() { }
        static void AtualizarStatus() { }

        static void ExibirMenu()
        {
            while (true)
            {
                Console.Clear();
                Console.WriteLine("=== Sistema de Imobiliária ===");
                Console.WriteLine("1. Cadastrar Imóvel");
                Console.WriteLine("2. Listar Imóveis");
                Console.WriteLine("3. Atualizar Status");
                Console.WriteLine("4. Cadastrar Parâmetros");
                Console.WriteLine("5. Sair");
                Console.Write("Escolha uma opção: ");

                int opcao = 0;

                try
                {
                    opcao = int.Parse(Console.ReadLine());
                }
                catch
                {
                    Console.WriteLine("Opção inválida. Pressione Enter para tentar novamente.");
                    Console.ReadLine();
                    continue;
                }

                switch (opcao)
                {
                    case 1:
                        CadastrarImovel();
                        break;
                    case 2:
                        ListarImoveis();
                        break;
                    case 3:
                        AtualizarStatus();
                        break;
                    case 4:
                        CadastrarParametros();
                        break;
                    case 5:
                        Console.WriteLine("Encerrando o sistema");
                        return;
                    default:
                        Console.WriteLine("Opção inválida!");
                        Console.ReadLine();
                        break;
                }
            }
        }
    }
}


